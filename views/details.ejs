<html></html>
  <head>
    <title>Message Details</title>

    <style>
      /* --- Page --- */
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        background: #f4f7fb;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
      }

      /* --- Card container --- */
      .container {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        width: 500px;
        max-width: 90%;
      }

      h1 {
        margin-top: 0;
        margin-bottom: 1.5rem;
        color: #2c3e50;
        text-align: center;
      }

      /* --- Message info rows --- */
      .detail {
        background: #f9fafc;
        border: 1px solid #e6eaf0;
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 12px;
      }

      .label {
        font-size: 13px;
        color: #7a869a;
        margin-bottom: 4px;
      }

      .value {
        font-size: 15px;
        color: #34495e;
        margin: 0;
      }

      /* --- Back button --- */
      .back-btn {
        margin-top: 1rem;
        width: 100%;
        background: #4f8cff;
        color: white;
        border: none;
        padding: 10px;
        border-radius: 6px;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.2s ease;
      }

      .back-btn:hover {
        background: #3a73d9;
        transform: translateY(-1px);
      }

      a {
        text-decoration: none;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <h1>Message Details</h1>

      <div class="detail">
        <div class="label">Sent by</div>
        <p class="value"><%= message.user %></p>
      </div>

      <div class="detail">
        <div class="label">Message</div>
        <p class="value"><%= message.text %></p>
      </div>

      <div class="detail">
        <div class="label">Time</div>
        <p class="value"><%= message.sent_at.toLocaleString() %></p>
      </div>

      <a href="/">
        <button class="back-btn">← Back to Messages</button>
      </a>
    </div>
  </body>
</html>
