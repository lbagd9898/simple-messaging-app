<html></html>
  <head>
    <title>Message App</title>

    <style>
      /* --- Page --- */
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        background: #f4f7fb;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 2rem;
      }

      /* --- Main container --- */
      .container {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        width: 600px;
        max-width: 90%;
      }

      h1 {
        margin-top: 0;
        color: #2c3e50;
        text-align: center;
      }

      /* --- Message list --- */
      ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      li {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f9fafc;
        padding: 12px 16px;
        border-radius: 8px;
        border: 1px solid #e6eaf0;
      }

      li p {
        margin: 0;
        color: #34495e;
        font-size: 15px;
      }

      /* --- Button --- */
      button {
        background: #4f8cff;
        color: white;
        border: none;
        padding: 8px 14px;
        border-radius: 6px;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.2s ease;
      }

      button:hover {
        background: #3a73d9;
        transform: translateY(-1px);
      }

      a {
        text-decoration: none;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <h1>Message Board</h1>

      <ul>
        <% messages.forEach((message) => { %>
          <li>
            <p><strong><%= message.user %></strong> — <%= message.text %></p>
            <a href="/message?msgId=<%= message.id %>">
              <button>Message details</button>
            </a>
          </li>
        <% }) %>
      </ul>
    </div>
    <a href="/new"><button>New Message</button></a>
  </body>
</html>
